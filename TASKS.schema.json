{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/tasks-schema.json",
  "title": "Multi-Agent Task Dispatcher TASKS.json",
  "description": "Schema for multi-agent task orchestration state file",
  "type": "object",
  "required": ["version", "created_at", "tasks", "scheduler"],
  "properties": {
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$",
      "description": "Schema version"
    },
    "created_at": {
      "type": "string",
      "format": "date-time",
      "description": "Creation timestamp"
    },
    "updated_at": {
      "type": "string",
      "format": "date-time",
      "description": "Last update timestamp"
    },
    "scheduler": {
      "type": "object",
      "required": ["max_parallel", "retry_policy"],
      "properties": {
        "max_parallel": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 3,
          "description": "Maximum parallel sub-agents"
        },
        "retry_policy": {
          "type": "object",
          "required": ["max_attempts", "backoff_seconds"],
          "properties": {
            "max_attempts": {
              "type": "integer",
              "minimum": 1,
              "maximum": 5,
              "default": 3
            },
            "backoff_seconds": {
              "type": "array",
              "items": { "type": "integer" },
              "minItems": 1,
              "default": [5, 25, 125]
            }
          }
        },
        "rate_limit": {
          "type": "object",
          "properties": {
            "requests_per_minute": { "type": "integer" },
            "tokens_per_minute": { "type": "integer" }
          }
        }
      }
    },
    "tasks": {
      "type": "array",
      "items": {
        "$ref": "#/definitions/task"
      }
    },
    "file_locks": {
      "type": "object",
      "additionalProperties": {
        "type": "string",
        "description": "task_id holding the lock"
      }
    },
    "health": {
      "type": "object",
      "properties": {
        "last_check": { "type": "string", "format": "date-time" },
        "stuck_tasks": {
          "type": "array",
          "items": { "type": "string" }
        },
        "context_usage": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        }
      }
    },
    "audit_log": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["time", "agent", "action"],
        "properties": {
          "time": { "type": "string", "format": "date-time" },
          "agent": { "type": "string" },
          "action": { "type": "string" },
          "task": { "type": "string" },
          "details": { "type": "string" }
        }
      }
    }
  },
  "definitions": {
    "task": {
      "type": "object",
      "required": ["id", "description", "status", "depends_on"],
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[A-Z][A-Z0-9]*-\\d+$",
          "description": "Task ID (e.g., T3-1, TASK-A1)"
        },
        "description": {
          "type": "string",
          "minLength": 10,
          "description": "Human-readable task description"
        },
        "status": {
          "type": "string",
          "enum": ["pending", "running", "completed", "verified", "failed", "blocked", "fatal"],
          "default": "pending"
        },
        "priority": {
          "type": "integer",
          "minimum": 1,
          "description": "Lower number = higher priority"
        },
        "depends_on": {
          "type": "array",
          "items": { "type": "string" },
          "description": "List of task IDs this task depends on"
        },
        "parallel_group": {
          "type": "string",
          "description": "Group name for semantic task grouping"
        },
        "created_at": { "type": "string", "format": "date-time" },
        "started_at": { "type": ["string", "null"], "format": "date-time" },
        "completed_at": { "type": ["string", "null"], "format": "date-time" },
        "retry_count": {
          "type": "integer",
          "default": 0,
          "maximum": 5
        },
        "summary_file": {
          "type": ["string", "null"],
          "description": "Path to summary JSON file"
        },
        "artifacts": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Files created by this task"
        },
        "verified": {
          "type": "boolean",
          "default": false
        },
        "verified_by": {
          "type": ["string", "null"]
        },
        "verified_at": {
          "type": ["string", "null"],
          "format": "date-time"
        },
        "error": {
          "type": ["object", "null"],
          "properties": {
            "type": {
              "type": "string",
              "enum": ["retryable", "fatal", "blocked"]
            },
            "code": { "type": "string" },
            "message": { "type": "string" },
            "stack": { "type": "string" }
          }
        },
        "next_retry_at": {
          "type": ["string", "null"],
          "format": "date-time"
        }
      }
    }
  }
}